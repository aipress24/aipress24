{% include "pages/member/member--tab-bar.j2" %}

<div class="py-6 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
  <h2 class="text-xl font-medium mb-2">Press Book</h2>

  <p class="mb-4 text-sm text-gray-600">
    Articles pour lesquels {{ profile.name }} détient un justificatif de
    publication (ticket #0195).
  </p>

  {% if press_book %}
    <ul role="list" class="grid gap-6 grid-cols-1 md:grid-cols-2">
      {% for post in press_book %}
        <li class="bg-white rounded shadow">
          {{ component("post-card", post, class_="bg-gray-100") }}
        </li>
      {% endfor %}
    </ul>
  {% else %}
    <p class="text-sm text-gray-600 italic">
      Aucun justificatif de publication enregistré à ce jour.
    </p>
  {% endif %}
</div>
