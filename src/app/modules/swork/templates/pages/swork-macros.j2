{% macro make_post(post) %}
  <li class="bg-white px-4 py-6 shadow sm:p-6 sm:rounded-lg">
    <article>
      <div>
        <div class="flex space-x-3">
          <div class="flex-shrink-0">
            <a href="{{ url_for(post.owner) }}">
              {{ profile_image(post.owner, size=10) }}
            </a>
          </div>

          <div class="min-w-0 flex-1">
            <p class="text-sm font-medium text-gray-900">
              <a href="{{ url_for(post.owner) }}" class="hover:underline">{{ post.owner.full_name }}</a>
            </p>

            <p class="text-sm text-gray-500">
              <time datetime="{{ post.created_at.isoformat() }}">
                {{ post.created_at.format('Le DD MMM YYYY à HH:mm', locale='fr') }}
              </time>
            </p>
          </div>
        </div>
      </div>

      {# Bug #0126 v4 — root cause discovered: `.j2` templates do NOT
         autoescape in Flask. A user typing `<b>...<b>` (unclosed tag)
         in a post leaked into the page DOM, broke HTML parsing, and
         cascaded into the SOCIAL aside being squashed to ~40px wide.
         Same defect was also a stored-XSS vector — `<script>` in a
         post would have executed.

         Explicit `|e` filter here as the surgical fix. A wider audit
         on every `.j2` `{{ var }}` is required separately. #}
      <div class="mt-2 text-sm text-gray-700 space-y-4 break-all">
        {{ post.content|e }}
      </div>

      <div class="mt-6 flex justify-between space-x-8">
        <div class="flex space-x-6">
          <span class="inline-flex items-center text-sm">
            <button
                type="button"
                class="inline-flex space-x-2 text-gray-400 hover:text-gray-500"
                hx-post="{{ url_for('api.likes', id=post.id, cls='post') }}"
                hx-vals='{"action": "toggle", }'
                hx-target="#likes-{{ post.id }}"
                hx-swap="innerHTML"
            >
              {{ icon("hand-thumb-up", class="h-5 w-5") }}
              <span id="likes-{{ post.id }}" class="font-medium text-gray-900">{{ post.like_count }}</span>
              <span class="sr-only">likes</span>
            </button>
          </span>
        </div>
      </div>
    </article>
  </li>
{% endmacro %}
