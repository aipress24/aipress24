{% extends "wip/layout/_base.j2" %}

{# Bug #0188 — Marketplace tab of WIP/Opportunités. Shows the
   current user's sent and received candidacies for one of
   { missions, projects, jobs }. Confidentiality : the page is
   strictly scoped to the logged-in user (server-side filter), no
   other applicant's message ever surfaces. #}

{% macro render_application_row(application, offer) %}
  <tr>
    <td class="px-3 py-2">
      <a class="text-blue-600 hover:underline"
         href="{{ url_for(detail_endpoint, id=offer.id) }}">
        {{ offer.title }}
      </a>
    </td>
    <td class="px-3 py-2">
      {% if application.owner %}
        <a class="text-blue-600 hover:underline"
           href="{{ url_for('swork.member', id=application.owner.id) }}"
           target="_blank" rel="noopener">
          {{ application.owner.full_name }}
        </a>
      {% else %}
        <span class="text-gray-400 italic">Candidat inconnu</span>
      {% endif %}
    </td>
    <td class="px-3 py-2 max-w-md">
      <p class="text-sm text-gray-700 truncate"
         title="{{ application.message }}">
        {{ application.message }}
      </p>
    </td>
    <td class="px-3 py-2 text-sm">
      {% if application.status.value == "SELECTED" %}
        <span class="bg-green-100 text-green-700 text-xs px-2 py-1 rounded">Sélectionné</span>
      {% elif application.status.value == "REJECTED" %}
        <span class="bg-red-100 text-red-700 text-xs px-2 py-1 rounded">Refusé</span>
      {% else %}
        <span class="bg-yellow-100 text-yellow-700 text-xs px-2 py-1 rounded">En attente</span>
      {% endif %}
      {% if application.decision_message %}
        <div class="text-xs text-gray-600 italic mt-1 max-w-md"
             title="{{ application.decision_message }}">
          « {{ application.decision_message }} »
        </div>
      {% endif %}
    </td>
    <td class="px-3 py-2 text-xs text-gray-500">
      {% if application.created_at %}
        {{ application.created_at.format("DD/MM/YYYY", locale="fr") if application.created_at.format else application.created_at }}
      {% endif %}
    </td>
  </tr>
{% endmacro %}

{% block body_content %}
  {% if tabs %}
    <nav class="mb-6 border-b border-gray-200">
      <ul class="flex flex-wrap gap-x-6">
        {% for tab in tabs %}
          <li>
            <a href="{{ tab.href }}"
               class="inline-block py-2 px-1 text-sm font-medium border-b-2 {% if tab.active %}border-indigo-600 text-indigo-700{% else %}border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300{% endif %}">
              {{ tab.label }}
            </a>
          </li>
        {% endfor %}
      </ul>
    </nav>
  {% endif %}

  <h2 class="text-lg font-medium text-gray-900 mb-3">Mes candidatures</h2>
  {% if sent_applications %}
    <div class="overflow-x-auto mb-8">
      <table class="dui-table dui-table-zebra border w-full">
        <thead>
          <tr>
            <th class="px-3 py-2 text-left">{{ offer_label }}</th>
            <th class="px-3 py-2 text-left">Candidat</th>
            <th class="px-3 py-2 text-left">Message</th>
            <th class="px-3 py-2 text-left">Statut</th>
            <th class="px-3 py-2 text-left">Envoyée le</th>
          </tr>
        </thead>
        <tbody>
          {% for application, offer in sent_applications %}
            {{ render_application_row(application, offer) }}
          {% endfor %}
        </tbody>
      </table>
    </div>
  {% else %}
    <p class="text-sm text-gray-600 mb-8">
      Vous n'avez encore envoyé aucune candidature.
    </p>
  {% endif %}

  <h2 class="text-lg font-medium text-gray-900 mb-3">Candidatures reçues</h2>
  {% if received_applications %}
    <div class="overflow-x-auto">
      <table class="dui-table dui-table-zebra border w-full">
        <thead>
          <tr>
            <th class="px-3 py-2 text-left">{{ offer_label }}</th>
            <th class="px-3 py-2 text-left">Candidat</th>
            <th class="px-3 py-2 text-left">Message</th>
            <th class="px-3 py-2 text-left">Statut</th>
            <th class="px-3 py-2 text-left">Reçue le</th>
          </tr>
        </thead>
        <tbody>
          {% for application, offer in received_applications %}
            {{ render_application_row(application, offer) }}
          {% endfor %}
        </tbody>
      </table>
    </div>
  {% else %}
    <p class="text-sm text-gray-600">
      Aucune candidature reçue sur vos offres pour le moment.
    </p>
  {% endif %}
{% endblock %}
