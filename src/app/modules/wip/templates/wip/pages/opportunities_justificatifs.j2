{% extends "wip/layout/_base.j2" %}

{# Ticket #0195 — WORK/OPPORTUNITÉS / « Justificatifs de publication ».
   Persistent list of JdP invitations received by the user (bell
   notifications from the journalist side) plus completed purchases. #}

{% block body_content %}
    {% if tabs %}
        <nav class="mb-6 border-b border-gray-200">
            <ul class="flex flex-wrap gap-x-6">
                {% for tab in tabs %}
                    <li>
                        <a href="{{ tab.href }}"
                           class="inline-block py-2 px-1 text-sm font-medium border-b-2 {% if tab.active %}border-indigo-600 text-indigo-700{% else %}border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300{% endif %}">
                            {{ tab.label }}
                        </a>
                    </li>
                {% endfor %}
            </ul>
        </nav>
    {% endif %}

    {# Completed purchases #}
    {% if purchases %}
        <h2 class="text-lg font-medium text-gray-900 mb-3">Justificatifs acquis</h2>
        <ul role="list" class="divide-y divide-gray-200 border rounded-lg mb-6">
            {% for p in purchases %}
                <li class="py-3 px-4">
                    <a class="text-blue-600 hover:underline font-medium"
                       href="{{ p.article_url }}">
                        {{ p.article_title }}
                    </a>
                    <span class="ml-2 text-xs text-gray-500">
                        {{ p.date.strftime("%d/%m/%Y") if p.date else "" }}
                    </span>
                </li>
            {% endfor %}
        </ul>
    {% endif %}

    {# Pending invitations #}
    <h2 class="text-lg font-medium text-gray-900 mb-3">Invitations reçues</h2>
    {% if invitations %}
        <ul role="list" class="divide-y divide-gray-200 border rounded-lg">
            {% for inv in invitations %}
                <li class="py-3 px-4 flex items-start justify-between">
                    <div>
                        <a class="text-blue-600 hover:underline font-medium"
                           href="{{ inv.article_url }}">
                            {{ inv.article_title }}
                        </a>
                        <span class="ml-2 text-xs text-gray-500">
                            par {{ inv.journalist_name }}
                        </span>
                    </div>
                    <span class="text-xs text-gray-500 whitespace-nowrap ml-4">
                        {{ inv.date.strftime("%d/%m/%Y") if inv.date else "\u2014" }}
                    </span>
                </li>
            {% endfor %}
        </ul>
    {% elif not purchases %}
        <p class="text-sm text-gray-600">
            Aucune invitation ni justificatif pour le moment.
        </p>
    {% else %}
        <p class="text-sm text-gray-600">
            Aucune invitation de justificatif en attente.
        </p>
    {% endif %}
{% endblock %}
