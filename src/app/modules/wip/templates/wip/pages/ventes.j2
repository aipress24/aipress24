{% extends "wip/layout/_base.j2" %}

{% macro render_rows_table(rows) %}
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
        <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Type</th>
        <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Article</th>
        <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 uppercase">Montant (HT)</th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200">
      {% for r in rows %}
        <tr>
          <td class="px-4 py-2 whitespace-nowrap text-sm text-gray-700">
            {{ r.date.strftime("%d/%m/%Y") if r.date else "" }}
          </td>
          <td class="px-4 py-2 text-sm text-gray-700">{{ r.type_label }}</td>
          <td class="px-4 py-2 text-sm text-gray-900">
            <a href="{{ r.post_url }}" class="text-pink-700 hover:underline">{{ r.post_title }}</a>
          </td>
          <td class="px-4 py-2 text-right text-sm text-gray-700">{{ "%.2f"|format(r.amount_eur) }} €</td>
        </tr>
      {% endfor %}
    </tbody>
  </table>
{% endmacro %}

{% block body_content %}
  <section class="mb-8">
    <div class="mb-4 bg-gray-50 border border-gray-200 rounded p-4">
      <div class="text-xs uppercase text-gray-500">Cumul de mes ventes éditoriales</div>
      <div class="text-2xl font-semibold text-gray-900">{{ "%.2f"|format(own_total_eur) }} € HT</div>
    </div>

    {% if own_rows %}
      {{ render_rows_table(own_rows) }}
    {% else %}
      <p class="text-sm text-gray-600">
        Vous n'avez pas encore de vente sur vos articles. Les achats effectués
        par les membres d'AiPRESS24 apparaîtront ici une fois facturés.
      </p>
    {% endif %}
  </section>

  {% if show_media_section %}
    <section class="mt-10 pt-6 border-t border-gray-200">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">
        Ventes du média (vue rédacteur en chef)
      </h2>
      <div class="mb-4 bg-gray-50 border border-gray-200 rounded p-4">
        <div class="text-xs uppercase text-gray-500">Cumul des ventes du média</div>
        <div class="text-2xl font-semibold text-gray-900">{{ "%.2f"|format(media_total_eur) }} € HT</div>
      </div>

      {% if media_rows %}
        {{ render_rows_table(media_rows) }}
      {% else %}
        <p class="text-sm text-gray-600">
          Aucune vente n'a encore été enregistrée sur les articles publiés par votre média.
        </p>
      {% endif %}
    </section>
  {% endif %}
{% endblock %}
