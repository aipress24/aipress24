{% extends "wip/layout/_base.j2" %}

{# Ticket #0227 — WORK/OPPORTUNITÉS / « Consultations d'articles offertes ».
   Persistent list of the articles offered to the current user so a gift
   recipient can reach them without hunting the email link. Strictly scoped
   to the logged-in user (server-side filter). #}

{% block body_content %}
    {% if tabs %}
        <nav class="mb-6 border-b border-gray-200">
            <ul class="flex flex-wrap gap-x-6">
                {% for tab in tabs %}
                    <li>
                        <a href="{{ tab.href }}"
                           class="inline-block py-2 px-1 text-sm font-medium border-b-2 {% if tab.active %}border-indigo-600 text-indigo-700{% else %}border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300{% endif %}">
                            {{ tab.label }}
                        </a>
                    </li>
                {% endfor %}
            </ul>
        </nav>
    {% endif %}

    <h2 class="text-lg font-medium text-gray-900 mb-3">Consultations d'articles offertes</h2>
    {% if articles %}
        <ul role="list" class="divide-y divide-gray-200 border rounded-lg">
            {% for article in articles %}
                <li class="py-3 px-4">
                    <a class="text-blue-600 hover:underline font-medium"
                       href="{{ url_for(article) }}">
                        {{ article.title }}
                    </a>
                </li>
            {% endfor %}
        </ul>
    {% else %}
        <p class="text-sm text-gray-600">
            Aucun article ne vous a été offert pour le moment.
        </p>
    {% endif %}
{% endblock %}
