{% extends "wip/layout/_base.j2" %}

{% block body_content %}
    <div class="mb-6 grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="bg-gray-50 border border-gray-200 rounded p-4">
            <div class="text-xs uppercase text-gray-500">Cumul de mes achats éditoriaux</div>
            <div class="text-2xl font-semibold text-gray-900">{{ "%.2f"|format(user_total_eur) }} € HT</div>
        </div>
        <div class="bg-gray-50 border border-gray-200 rounded p-4">
            <div class="text-xs uppercase text-gray-500">Cumul des achats de mon organisation</div>
            <div class="text-2xl font-semibold text-gray-900">{{ "%.2f"|format(org_total_eur) }} € HT</div>
        </div>
    </div>

    {% if rows %}
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
                    <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Type</th>
                    <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Article</th>
                    <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 uppercase">Montant (HT)</th>
                    <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Statut</th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
                {% for r in rows %}
                    <tr>
                        <td class="px-4 py-2 whitespace-nowrap text-sm text-gray-700">
                            {{ r.date.strftime("%d/%m/%Y") if r.date else "" }}
                        </td>
                        <td class="px-4 py-2 text-sm text-gray-700">{{ r.type_label }}</td>
                        <td class="px-4 py-2 text-sm text-gray-900">
                            <a href="{{ r.post_url }}" class="text-pink-700 hover:underline">{{ r.post_title }}</a>
                        </td>
                        <td class="px-4 py-2 text-right text-sm text-gray-700">{{ "%.2f"|format(r.amount_eur) }} €</td>
                        <td class="px-4 py-2 text-sm">
                            {% if r.is_refunded %}
                                <span class="text-gray-500">Remboursé</span>
                            {% else %}
                                <span class="text-green-700">Payé</span>
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p class="text-sm text-gray-600">
            Vous n'avez pas encore acquis d'article. Vos achats apparaîtront ici dès qu'ils auront été facturés.
        </p>
    {% endif %}
{% endblock %}
