{# Two-level cascade selector for the ciblage page.

   Adapted from `src/app/modules/kyc/lib/dual_select_multi.j2` so we
   inherit the KYC fix for bug #0119 (the second dropdown
   truncation). Differences vs. the KYC widget:

   - Takes a `selector` arg (not WTForms `field`) — see DualSelector
     in expert_selectors.py for the shape contract.
   - The Tom-Select script tag is loaded once by `ciblage.j2`
     itself; we do NOT include it here (would otherwise re-load
     7 times, once per dual selector instance).
   - HTMX onChange hook: any selection (parent or child) re-fires
     the ciblage search exactly like the flat selectors do, so the
     candidate list updates live.
#}
<div class="aui-field-group mb-4 col-span-1 lg:col-span-2"
     x-data="{
       all_options: {{ selector.get_dual_tom_choices_for_js() }},
       value: {{ selector.get_data() }},
       second_value: {{ selector.get_data2() }},
       last_val: [],
       current_val: [],
       second_list: null,
       init() {
         this.$nextTick(() => {
           const parentSelect = new TomSelect(this.$refs.parent_select, {
             maxOptions: null,
             maxItems: null,
             options: this.all_options.field1,
             preload: false,
             labelField: 'label',
             searchField: ['label'],
             diacritics: true,
             plugins: { remove_button: { title: 'Retirer' } }
           });

           const childSelect = new TomSelect(this.$refs.child_select, {
             maxOptions: null,
             maxItems: null,
             preload: false,
             labelField: 'label',
             searchField: ['label'],
             diacritics: true,
             plugins: { remove_button: { title: 'Retirer' } }
           });
           childSelect.disable();

           const fireSearchUpdate = () => {
             let values = htmx.values(htmx.find('#search-form'));
             values.selector_change = 1;
             const url = '{{ url_for("AvisEnqueteWipView:ciblage", id=model.id) }}';
             htmx.ajax('GET', url, {
               target: '#main',
               select: '#main',
               values: values
             });
           };

           const refreshChild = () => {
             const selection = JSON.parse(JSON.stringify(this.value));
             if (selection
                 && JSON.stringify(selection) !== JSON.stringify(this.last_val)) {
               this.last_val = selection;
               this.second_list = [];
               for (const el of this.all_options.field2) {
                 const key = el.value.split(' / ')[0];
                 if (selection.includes(key)) {
                   this.second_list.push(el);
                 }
               }
               displayChildList();
             }
           };

           const displayChildList = () => {
             if (this.current_val === this.last_val) return;
             // Preserve current child selection across re-renders so a
             // user who flips a parent off doesn't lose unrelated picks.
             const keepValues = childSelect.getValue();
             childSelect.clear();
             childSelect.clearOptions();
             childSelect.addOptions(this.second_list);
             // refreshOptions(false) — bug #0119 fix: passing the option
             // array misfires the API and truncates the dropdown at
             // ~50 items. Boolean only.
             childSelect.refreshOptions(false);
             childSelect.enable();
             // Re-apply selections that survive the new parent set.
             const validValues = new Set(this.second_list.map(o => o.value));
             const surviving = (Array.isArray(keepValues) ? keepValues : [keepValues])
               .filter(v => validValues.has(v));
             if (surviving.length) {
               childSelect.setValue(surviving, true);
             }
             this.current_val = this.last_val;
           };

           if (this.value.length > 0) {
             parentSelect.setValue(this.value, true);
           }

           this.$refs.parent_select.addEventListener('change', () => {
             this.value = parentSelect.getValue();
             refreshChild();
             fireSearchUpdate();
           });

           this.$refs.child_select.addEventListener('change', () => {
             fireSearchUpdate();
           });

           refreshChild();
           if (this.second_value.length > 0) {
             childSelect.setValue(this.second_value, true);
           }
         });
       }
     }">
  <label for="{{ selector.parent_id }}" class="font-bold block mb-1">
    {{ selector.label }}
  </label>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
    <div>
      <span class="text-xs text-gray-600">{{ selector.parent_label }}</span>
      <select
          x-ref="parent_select"
          id="{{ selector.parent_id }}"
          name="{{ selector.parent_id }}"
          multiple>
      </select>
    </div>
    <div>
      <span class="text-xs text-gray-600">Détail</span>
      <select
          x-ref="child_select"
          id="{{ selector.id }}"
          name="{{ selector.id }}"
          multiple>
      </select>
    </div>
  </div>
</div>
