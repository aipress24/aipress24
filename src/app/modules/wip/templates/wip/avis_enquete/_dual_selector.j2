{# Two-level cascade selector for the ciblage page.

   Renders a parent → child cascade. Carries the cascade payload on
   `data-*` attributes; ciblage.j2 has a single `initDualSelectors()`
   pass that wires Tom-Select on every `.dual-select-cascade` element.

   Why no Alpine here:
   - The earlier Alpine-based version (commit e5eadd37) used
     `x-data="{ ... JSON.parse(document.getElementById(...).textContent) ... }"`
     to feed the cascade. On the live page Tom-Select still didn't
     init — easier to debug a single vanilla setup function than seven
     parallel Alpine instances reading JSON across the DOM.
   - The flat selectors already use a vanilla `querySelectorAll`
     pattern that polls until TomSelect is loaded; reusing that
     pattern keeps the page consistent.

   `data-options`, `data-value`, `data-second-value` carry the JSON
   payload (Flask's `tojson` makes it HTML-attribute-safe — `'`, `<`,
   `>`, `&` all escaped to `\\uXXXX`). `data-ajax-url` carries the
   HTMX search URL so the setup function can re-fire the search on
   selection change.
#}
<div class="aui-field-group mb-4 col-span-1 lg:col-span-2 dual-select-cascade"
     data-options='{{ selector.get_dual_tom_choices_for_js() | tojson }}'
     data-value='{{ selector.get_data() | tojson }}'
     data-second-value='{{ selector.get_data2() | tojson }}'
     data-ajax-url='{{ url_for("AvisEnqueteWipView:ciblage", id=model.id) }}'>
  <label for="{{ selector.parent_id }}" class="font-bold block mb-1">
    {{ selector.label }}
  </label>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
    <div>
      <span class="text-xs text-gray-600 block mb-1">{{ selector.parent_label }}</span>
      <select
          data-role="parent"
          id="{{ selector.parent_id }}"
          name="{{ selector.parent_id }}"
          multiple>
      </select>
    </div>
    <div>
      <span class="text-xs text-gray-600 block mb-1">Détail</span>
      <select
          data-role="child"
          id="{{ selector.id }}"
          name="{{ selector.id }}"
          multiple>
      </select>
    </div>
  </div>
</div>
