{% extends "layout.html" %}

{% block content %}
<div class="max-w-2xl mx-auto py-12 px-6">
  <div class="bg-white p-8 rounded-lg shadow border border-green-200">
    <h1 class="text-2xl font-semibold text-green-700 mb-4">
      Paiement confirmé
    </h1>
    <p class="text-gray-700 mb-4">
      Merci pour votre achat. Votre transaction a été prise en compte ;
      selon le produit, l'effet (accès au contenu, justificatif PDF,
      licence de reproduction) sera disponible sous peu.
    </p>
    <dl class="mt-6 space-y-2 text-sm text-gray-600">
      <div class="flex justify-between">
        <dt>Produit</dt>
        <dd>{{ purchase.product_type.value }}</dd>
      </div>
      <div class="flex justify-between">
        <dt>Statut</dt>
        <dd>{{ purchase.status.value }}</dd>
      </div>
    </dl>
    <a href="{{ back_url }}"
       class="mt-6 inline-flex items-center text-blue-600 hover:underline">
      ← Retour à l'article
    </a>
  </div>
</div>
{% endblock %}
