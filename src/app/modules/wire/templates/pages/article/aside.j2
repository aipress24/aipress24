{# Purchase Actions — MVP Stripe one-off checkout.
   Ticket #0193 — each button now opens an HTMX confirmation modal
   first (cf. `pages/purchase/buy_modal.j2`) showing HT/TVA/TTC + the
   cumul de vos achats individuel + organisationnel. The modal's
   « Accepter » button is the one that POSTs to /wire/<id>/buy/<product>. #}
<div class="mb-6 pb-6 border-b border-gray-200">
    <h2 class="text-xl font-medium text-gray-700 mb-4">Acquisition</h2>

    {% set btn_class = "w-full flex items-center justify-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-teal-500 transition-colors disabled:opacity-50 disabled:cursor-not-allowed" %}
    {% set post_id = post._model.id if post._model is defined else post.id %}

    <div id="purchase-modal"></div>

    <div class="space-y-3">
    {# Droit de consultation #}
        <button type="button"
                class="{{ btn_class }}"
                title="Accéder au contenu complet de l'article"
                hx-get="{{ url_for('wire.buy_modal', post_id=post_id, product='consultation') }}"
                hx-target="#purchase-modal"
                hx-swap="innerHTML">
            {{ icon("eye", class="h-5 w-5 mr-2 text-gray-500") }}
            Droit de consultation
        </button>

    {# Ticket #0194 — Droit de consultation offerte #}
        <button type="button"
                class="{{ btn_class }}"
                title="Offrir cet article à d'autres membres d'AiPRESS24"
                hx-get="{{ url_for('wire.buy_modal_gift', post_id=post_id) }}"
                hx-target="#purchase-modal"
                hx-swap="innerHTML">
            {{ icon("gift", class="h-5 w-5 mr-2 text-gray-500") }}
            Droit de consultation offerte
        </button>

    {# Justificatif de publication #}
        <button type="button"
                class="{{ btn_class }}"
                title="Obtenir un justificatif officiel de publication"
                hx-get="{{ url_for('wire.buy_modal', post_id=post_id, product='justificatif') }}"
                hx-target="#purchase-modal"
                hx-swap="innerHTML">
            {{ icon("document-check", class="h-5 w-5 mr-2 text-gray-500") }}
            Justificatif de publication
        </button>

    {# Droits de reproduction / Cession — hidden when clearly ineligible
       per the article's frozen rights-sales policy. #}
        {% if can_cede %}
            <button type="button"
                    class="{{ btn_class }}"
                    title="Acquérir les droits de reproduction de l'article"
                    hx-get="{{ url_for('wire.buy_modal', post_id=post_id, product='cession') }}"
                    hx-target="#purchase-modal"
                    hx-swap="innerHTML">
                {{ icon("shield-check", class="h-5 w-5 mr-2 text-gray-500") }}
                Droits de reproduction
            </button>
        {% endif %}
    </div>
</div>

<h2 class="text-xl font-medium text-gray-700">Métadonnées</h2>

<div class="py-5 space-y-5">
    <div>
        <h3 class="text-sm font-medium text-gray-500">Activité</h3>

        <ul role="list" class="mt-3 space-y-3">
            {% if post.published_at %}
                <li class="flex items-center space-x-2">
                    {{ icon("calendar", class="h-5 w-5 text-gray-400") }}

                    <span class="text-gray-900 text-sm font-medium"
                    >Publié le <time datetime="{{ post.published_at.isoformat() }}"
                        >{{ post.published_at.format("DD MMMM YYYY, à HH:mm", locale="fr") }}</time></span
                        >
                    </li>
            {% endif %}

            {% if post.modified_at %}
                <li class="flex items-center space-x-2">
                    {{ icon("calendar", class="h-5 w-5 text-gray-400") }}

                    <span class="text-gray-900 text-sm font-medium"
                    >Modifié le <time datetime="{{ post.modified_at.isoformat() }}"
                        >{{ post.modified_at.format("DD MMMM YYYY, à HH:mm", locale="fr") }}</time></span
                        >
                    </li>
            {% endif %}

            {% if purchase_info %}
                <li class="flex items-center space-x-2">
                    {% if purchase_info.is_gift %}
                        {{ icon("gift", class="h-5 w-5 text-gray-400") }}
                        <span class="text-gray-900 text-sm font-medium"
                        >Offert le <time datetime="{{ purchase_info.date.isoformat() }}"
                            >{{ purchase_info.date.format("DD MMMM YYYY, à HH:mm", locale="fr") }}</time></span
                            >
                    {% else %}
                        {{ icon("shopping-bag", class="h-5 w-5 text-gray-400") }}
                        <span class="text-gray-900 text-sm font-medium"
                        >Acheté le <time datetime="{{ purchase_info.date.isoformat() }}"
                            >{{ purchase_info.date.format("DD MMMM YYYY, à HH:mm", locale="fr") }}</time></span
                            >
                    {% endif %}
                </li>
            {% endif %}

            <li>
                <a class="flex items-center space-x-2" href="#comments-title">
                    {{ icon("chat-bubble-left-ellipsis", class="h-5 w-5 text-gray-400") }}
                    <span class="text-gray-900 text-sm font-medium">{{ post.comment_count }} commentaires</span>
                </a>
            </li>
        </ul>
    </div>

    <div>
        <h3 class="text-sm font-medium text-gray-500">Créateur / créatrice</h3>

        <ul role="list" class="mt-3 space-y-3">
            <li class="flex justify-start">
                <a href="{{ url_for(post.author) }}" class="flex items-center space-x-3">
                    <div class="flex-shrink-0">
                        {{ profile_image(post.author, size=5) }}
                    </div>
                    <div
                        class="ml-2 text-sm font-medium text-gray-900 hover:underline"
                    >{{ post.author.full_name }}</div>
                </a>
            </li>
        </ul>
    </div>

    {% if post.publisher %}
        <div>
            <h3 class="text-sm font-medium text-gray-500">{{ post.publisher_type }}</h3>
            <a href="{{ url_for(post.publisher) }}"
               class="text-sm font-medium hover:underline">{{ post.publisher.name }}</a>
        </div>
    {% endif %}
    {% if post.media %}
        <div>
            <h3 class="text-sm font-medium text-gray-500">Pour le média</h3>
            <a href="{{ url_for(post.media) }}"
               class="text-sm font-medium hover:underline">
                {{ post.media.name }}</a>
        </div>
    {% endif %}

    {% for metadata in metadata_list %}
        <div>
            <h3 class="text-sm font-medium text-gray-500">{{ metadata.label }}</h3>

            <a href="{{ url_for(".wire") }}"
               class="text-sm font-medium hover:underline">{{ metadata.value }}</a>
        </div>
    {% endfor %}
</div>

<div class="border-t border-gray-200 py-6">
    <h2 class="text-sm font-medium text-gray-500 mb-4">Tags</h2>

    <ul role="list" class="leading-8">
        {% for tag in post.tags %}
            <li class="inline">
                {% if tag.type == "auto" %}
                    {% set color="rose" %}
                {% else %}
                    {% set color="blue" %}
                {% endif -%}

                <a href="{{ url_for(".wire", tab="wall", tag=tag.label) }}"
                   class="relative mb-2 inline-flex items-center rounded-full border border-gray-300 px-3 py-0 hover:underline">
                    <div class="absolute flex-shrink-0 flex items-center justify-center">
                        <span class="h-1.5 w-1.5 rounded-full bg-{{ color }}-500" aria-hidden="true"></span>
                    </div>
                    <div class="ml-3.5 text-sm font-medium text-gray-600">{{ tag.label }}</div>
                </a>
            </li>
        {% endfor %}
    </ul>
</div>
