{% extends "pages/preferences/_base.j2" %}

{% block main %}
    <h2 class="pb-4">Invitations à rejoindre une organisation</h2>

    {% if invitations|length > 0 %}
        {% for invit in invitations %}
            {% if invit.disabled %}
                <div class="text-sm text-gray-600">Vous êtes actuellement membre de l'organisation&nbsp;:</div>
                <div class="font-bold text-black mb-4">
                    {{ invit.label }}
                </div>
            {% endif %}
        {% endfor %}
    {% endif %}

    {% if open_invitations > 0 %}
        <p class="mt-1 text-sm text-gray-500 mb-4">
            Vous pouvez rejoindre le Business Wall d'une organisation&nbsp;:
        </p>
        <div class="space-y-4">
            {% for invit in invitations %}
                {% if not invit.disabled %}
                    <div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg border border-gray-200">
                        <div class="font-medium text-gray-900">{{ invit.label }}</div>
                        <button
                            type="button"
                            data-modal-target="confirm_join_org_{{ loop.index }}"
                            data-modal-toggle="confirm_join_org_{{ loop.index }}"
                            class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-500 hover:bg-indigo-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-400"
                        >
                            Rejoindre
                        </button>
                    </div>

                    <div id="confirm_join_org_{{ loop.index }}"
                         data-modal-backdrop="static"
                         tabindex="-1"
                         aria-hidden="true"
                         class="hidden overflow-y-auto overflow-x-hidden fixed top-0 right-0 left-0 z-50 justify-center items-center w-full md:inset-0 h-[calc(100%-1rem)] max-h-full">
                        <div class="relative p-4 w-full max-w-md max-h-full">
                            <div class="relative bg-white rounded-lg shadow dark:bg-gray-700">
                                <div class="p-4 md:p-5 text-center">
                                    <svg class="mx-auto mb-4 text-gray-400 w-12 h-12 dark:text-gray-200" aria-hidden="true"
                                         xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 20 20">
                                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M10 11V6m0 8h.01M19 10a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
                                    </svg>
                                    <h3 class="mb-1 text-lg font-normal text-gray-500 dark:text-gray-400">
                                        Confirmer l'adhésion au Business Wall&nbsp;:
                                    </h3>
                                    <p class="pt-2 pb-3 mb-4 text-center font-bold">
                                        {{ invit.label }}
                                    </p>
                                    <button
                                        data-modal-hide="confirm_join_org_{{ loop.index }}"
                                        type="button"
                                        hx-post="{{ url_for('.invitations') }}"
                                        hx-vals='{"action": "join_org", "target": "{{ invit.org_id }}" }'
                                        class="text-white bg-indigo-600 hover:bg-indigo-800 focus:ring-4 focus:outline-none focus:ring-indigo-300 font-medium rounded-lg text-sm inline-flex items-center px-5 py-2.5 text-center"
                                    >Oui, rejoindre
                                    </button>
                                    <button
                                        data-modal-hide="confirm_join_org_{{ loop.index }}"
                                        type="button"
                                        class="py-2.5 px-5 ms-3 text-sm font-medium text-gray-900 focus:outline-none bg-white rounded-lg border border-gray-200 hover:bg-gray-100 hover:text-blue-700 focus:z-10 focus:ring-4 focus:ring-gray-100"
                                    >Annuler
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                {% endif %}
            {% endfor %}
        </div>
    {% else %}
        <div class="text-sm text-gray-500 italic">
            Vous n'avez actuellement aucune invitation d'une organisation.
        </div>
    {% endif %}

    <h2 class="pb-4 pt-8 mt-8 border-t border-gray-200">Invitations à un rôle Business Wall</h2>
    {% if open_role_invitations > 0 %}
        <p class="mt-1 text-sm text-gray-500 mb-4">
            Vous avez été invité à occuper un rôle dans le Business Wall suivant&nbsp;:
        </p>
        <div class="space-y-4">
            {% for role_invit in role_invitations %}
                <div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg border border-gray-200">
                    <div>
                        <div class="font-medium text-gray-900">{{ role_invit.bw_name }}</div>
                        <div class="text-sm text-gray-600">
                            Rôle proposé&nbsp;: <span class="font-semibold">{{ role_invit.role_label }}</span>
                        </div>
                    </div>
                    <a href="{{ url_for('bw_activation.confirm_role_invitation', bw_id=role_invit.bw_id, role_type=role_invit.role_type, user_id=role_invit.user_id) }}"
                       class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm !text-white bg-indigo-500 hover:bg-indigo-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-400">
                        Voir l'invitation
                    </a>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="text-sm text-gray-900 font-bold">
            Vous n'avez actuellement aucune invitation à un rôle Business Wall.
        </div>
    {% endif %}

    {# Accepted roles (active) #}
    <h2 class="pb-4 pt-8 mt-8 border-t border-gray-200">Rôles Business Wall actifs</h2>
    {% if open_accepted_roles > 0 %}
        <p class="mt-1 text-sm text-gray-500 mb-4">
            Vous occupez actuellement le ou les rôles suivants&nbsp;:
        </p>
        <div class="space-y-4">
            {% for role in accepted_roles %}
                <div class="flex items-center justify-between p-4 bg-green-50 rounded-lg border border-green-200">
                    <div>
                        <div class="font-medium text-gray-900">{{ role.bw_name }}</div>
                        <div class="text-sm text-gray-600">
                            Rôle&nbsp;: <span class="font-semibold">{{ role.role_label }}</span>
                        </div>
                    </div>
                    <span class="inline-flex items-center px-3 py-1 text-sm font-medium rounded-full bg-green-100 text-green-800">
                        Confirmé
                    </span>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="text-sm text-gray-900 font-bold">
            Vous n'occupez actuellement aucun rôle Business Wall.
        </div>
    {% endif %}

  {# Partnership Invitations #}
    <h2 class="pb-4 pt-8 mt-8 border-t border-gray-200">Invitations à un partenariat Business Wall</h2>
    {% if open_partnership_invitations > 0 %}
        <p class="mt-1 text-sm text-gray-500 mb-4">
            Vous avez été invité à établir un partenariat (PR externe) avec le Business Wall suivant&nbsp;:
        </p>
        <div class="space-y-4">
            {% for partnership_invit in partnership_invitations %}
                <div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg border border-gray-200">
                    <div>
                        <div class="font-medium text-gray-900">{{ partnership_invit.bw_name }}</div>
                        <div class="text-sm text-gray-600">
                            Rôle proposé&nbsp;: <span class="font-semibold">{{ partnership_invit.role_label }}</span>
                        </div>
                    </div>
                    <a href="{{ url_for('bw_activation.confirm_partnership_invitation', bw_id=partnership_invit.bw_id, partnership_id=partnership_invit.id) }}"
                       class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm !text-white bg-indigo-500 hover:bg-indigo-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-400">
                        Voir l'invitation
                    </a>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="text-sm text-gray-900 font-bold">
            Vous n'avez actuellement aucune invitation à un partenariat Business Wall.
        </div>
    {% endif %}

  {# Ticket #0169 part 3 — surface revoked partnerships so the PR Agency
     owner knows they lost a client. The cloche + email cover the moment
     of revocation ; this section is the persistent acknowledgement
     point. The « Confirmer » button hard-deletes the row (Erick :
     « éliminer cette ligne »). #}
    {% if open_revoked_partnerships > 0 %}
        <h2 class="pb-4 pt-8 mt-8 border-t border-gray-200">Partenariats RP terminés</h2>
        <p class="mt-1 text-sm text-gray-500 mb-4">
            Vous avez été notifié de la fin d'un partenariat RP. Cliquez
            sur « Confirmer » pour retirer la ligne après prise de connaissance.
        </p>
        <div class="space-y-4">
            {% for revoked in revoked_partnerships %}
                <div class="flex items-center justify-between p-4 bg-red-50 rounded-lg border border-red-200" data-testid="revoked-partnership-row">
                    <div>
                        <div class="font-medium text-gray-900">
                            Fin du partenariat avec
                            <span class="font-semibold">{{ revoked.client_name }}</span>
                            (Business Wall : {{ revoked.bw_name }})
                        </div>
                        {% if revoked.revoked_at %}
                            <div class="text-sm text-gray-600">
                                Résiliation : {{ revoked.revoked_at.strftime('%d/%m/%Y') }}
                            </div>
                        {% endif %}
                    </div>
                    <form method="POST" action="{{ url_for('.invitations') }}">
                        <input type="hidden" name="action" value="ack_revoked_partnership">
                        <input type="hidden" name="partnership_id" value="{{ revoked.id }}">
                        <button type="submit"
                                class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm !text-white bg-gray-600 hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500">
                            Confirmer
                        </button>
                    </form>
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
