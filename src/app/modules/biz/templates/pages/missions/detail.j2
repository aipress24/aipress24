{% extends "layout/private.j2" %}
{% from "macros/_poster_card.j2" import poster_card %}

{% block content %}
<div class="py-10">
  <div class="mx-auto max-w-4xl px-6">
    <div class="bg-white p-6 rounded-lg shadow">
      <div class="flex items-center justify-between mb-4">
        <h1 class="text-2xl font-semibold text-gray-900">{{ mission.title }}</h1>
        {% if mission.mission_status.value == "filled" %}
          <span class="bg-gray-200 text-gray-700 text-xs px-2 py-1 rounded">Pourvue</span>
        {% elif mission.mission_status.value == "closed" %}
          <span class="bg-red-100 text-red-700 text-xs px-2 py-1 rounded">Fermée</span>
        {% else %}
          <span class="bg-green-100 text-green-700 text-xs px-2 py-1 rounded">Ouverte</span>
        {% endif %}
      </div>

      <dl class="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm text-gray-600 mb-6">
        {# Bug #0185 — show the category + sub-type pair when set. #}
        {% if mission.category %}
          <div>
            <dt class="text-gray-500">Type de mission</dt>
            <dd>
              {{ mission.category.value|capitalize }}{% if mission.subcategory %} · {{ mission.subcategory }}{% endif %}
            </dd>
          </div>
        {% endif %}
        {% if mission.sector %}
          <div><dt class="text-gray-500">Secteur</dt><dd>{{ mission.sector }}</dd></div>
        {% endif %}
        {% set _geo = mission|offer_geoloc %}
        {% if _geo %}
          <div><dt class="text-gray-500">Localisation</dt><dd>{{ _geo }}</dd></div>
        {% endif %}
        {% if mission.budget_min or mission.budget_max %}
          <div>
            <dt class="text-gray-500">Budget</dt>
            <dd>
              {% if mission.budget_min and mission.budget_max %}
                {{ (mission.budget_min / 100)|int }}&nbsp;€ — {{ (mission.budget_max / 100)|int }}&nbsp;€
              {% elif mission.budget_min %}
                à partir de {{ (mission.budget_min / 100)|int }}&nbsp;€
              {% elif mission.budget_max %}
                jusqu'à {{ (mission.budget_max / 100)|int }}&nbsp;€
              {% endif %}
            </dd>
          </div>
        {% endif %}
        {% if mission.deadline %}
          <div><dt class="text-gray-500">Deadline</dt><dd>{{ mission.deadline.strftime("%d/%m/%Y") }}</dd></div>
        {% endif %}
      </dl>

      {# `description` is TextAreaField (plain text). Stripped the
         original `|safe` — it was a stored-XSS vector. Newlines kept
         readable via `whitespace-pre-wrap`. #}
      <div class="prose max-w-none text-gray-800 mb-8 whitespace-pre-wrap">{{ mission.description }}</div>

      {# Bug #0187 — Journalism-extension fields. Each is a list of
         strings ; render only the ones that carry values. The two
         work-mode flags surface as chips. #}
      {% if mission.category and mission.category.value == "journalisme" %}
        {% set _jour_fields = [
            ("Métiers du journalisme", mission.metiers_journalisme),
            ("Types d'entreprises de presse & médias", mission.types_entreprises_presse_medias),
            ("Types presse & médias", mission.types_presse_medias),
            ("Compétences en journalisme", mission.competences_journalisme),
            ("Langues", mission.langues),
            ("Types de contenus éditoriaux", mission.types_contenus_editoriaux),
            ("Taille des contenus éditoriaux", mission.taille_contenus_editoriaux),
            ("Modes de rémunération", mission.modes_remuneration),
        ] %}
        {% set _has_jour = mission.physical_required or mission.remote_required or _jour_fields|selectattr(1)|list %}
        {% if _has_jour %}
          <div class="border-t border-gray-200 pt-6 mb-8">
            <h2 class="text-lg font-semibold text-gray-900 mb-3">
              Profil recherché
            </h2>
            <dl class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-3 text-sm">
              {% for label, values in _jour_fields %}
                {% if values %}
                  <div>
                    <dt class="text-gray-500">{{ label }}</dt>
                    <dd class="text-gray-800">{{ values|join(", ") }}</dd>
                  </div>
                {% endif %}
              {% endfor %}
            </dl>
            <div class="mt-3 flex flex-wrap gap-2">
              {% if mission.physical_required %}
                <span class="bg-amber-100 text-amber-800 text-xs px-2 py-1 rounded">
                  Présence physique requise
                </span>
              {% endif %}
              {% if mission.remote_required %}
                <span class="bg-emerald-100 text-emerald-800 text-xs px-2 py-1 rounded">
                  Télétravail
                </span>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endif %}

      {# Bug #0183 — mini-card du poster, avec lien BW si disponible. #}
      {% if mission.owner %}
        <div class="mb-8">
          {{ poster_card(mission.owner, title="Annoncée par", show_bw_link=True) }}
        </div>
      {% endif %}

      {% if is_owner %}
        <div class="border-t pt-6 flex flex-wrap gap-2">
          <a href="{{ url_for('.missions_applications', id=mission.id) }}"
             class="bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-md">
            Voir les candidatures reçues
          </a>
          {% if mission.mission_status.value == "open" %}
            <form method="post" action="{{ url_for('.missions_fill', id=mission.id) }}" class="inline">
              <button type="submit"
                      class="bg-gray-200 hover:bg-gray-300 text-gray-800 font-medium py-2 px-4 rounded-md">
                Marquer comme pourvue
              </button>
            </form>
          {% endif %}
        </div>
      {% elif user_application %}
        <div class="border-t pt-6 text-sm text-gray-700">
          Vous avez déjà candidaté le {{ user_application.created_at.format("DD/MM/YYYY") if user_application.created_at else "" }}.
          Statut : <strong>{{ user_application.status.value }}</strong>.
        </div>
      {% elif mission.mission_status.value == "open" %}
        <form method="post" action="{{ url_for('.missions_apply', id=mission.id) }}" class="border-t pt-6">
          <label class="block text-sm font-medium text-gray-700 mb-1">
            Votre message
          </label>
          <textarea name="message" rows="4" required
                    class="w-full px-3 py-2 border border-gray-300 rounded-md mb-4"
                    placeholder="Présentez-vous et expliquez pourquoi vous candidatez."></textarea>
          <button type="submit"
                  class="bg-green-600 hover:bg-green-700 text-white font-medium py-2 px-4 rounded-md">
            Candidater
          </button>
        </form>
      {% else %}
        <div class="border-t pt-6 text-sm text-gray-500 italic">
          Cette mission n'accepte plus de candidatures.
        </div>
      {% endif %}
    </div>

    <div class="mt-6">
      <a href="{{ url_for('biz.biz', current_tab='missions') }}"
         class="text-blue-600 hover:underline text-sm">
        ← Retour aux missions
      </a>
    </div>
  </div>
</div>
{% endblock %}
