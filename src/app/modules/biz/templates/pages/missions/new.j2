{% extends "layout/private.j2" %}
{% from "macros/_poster_card.j2" import poster_card %}

{% macro render_field(field, extra_class="") %}
  <div class="mb-4">
    {{ field.label(class="block text-sm font-medium text-gray-700 mb-1") }}
    {{ field(class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 " + extra_class + (" border-red-500" if field.errors else "")) }}
    {% if field.errors %}
      <div class="mt-1 text-sm text-red-600">
        {% for error in field.errors %}<span>{{ error }}</span>{% endfor %}
      </div>
    {% endif %}
  </div>
{% endmacro %}

{% block content %}
{# Hide browser spin buttons on numeric inputs marked .no-spinner
   (budget fields). Click-by-click entry was unusable in practice ;
   users now type the amount directly. Ref bug #0073. #}
<style>
  input.no-spinner::-webkit-outer-spin-button,
  input.no-spinner::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  input.no-spinner { -moz-appearance: textfield; }
</style>
<div class="py-10">
  <div class="mx-auto max-w-3xl px-6">
    <h1 class="text-2xl font-semibold text-gray-800 mb-6">
      Publier une mission
    </h1>
    <p class="text-sm text-gray-600 mb-6">
      Remplissez le formulaire ci-dessous pour publier votre proposition
      de mission ponctuelle. Elle s'affichera dans l'espace MARKET /
      Missions et les candidatures apparaîtront dans votre espace WORK /
      OPPORTUNITÉS / Missions sous forme de notifications.
    </p>
    <form method="post"
          x-data="{ category: '{{ form.category.data or '' }}' }"
          class="bg-white p-6 rounded-lg shadow">
      {{ render_field(form.title) }}
      {{ render_field(form.description, extra_class="min-h-[160px]") }}

      {# Bug #0185 — top-level category. The sub-category select
         below is mounted dynamically by Alpine.js based on this
         value (only one sub-select lives in the DOM at a time, so
         the form posts a single `subcategory` field). #}
      <div class="mb-4">
        {{ form.category.label(class="block text-sm font-medium text-gray-700 mb-1") }}
        {{ form.category(
            class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500",
            **{"x-model": "category"}
        ) }}
      </div>
      {% for cat_value, options in mission_subcategories.items() %}
        <template x-if="category === '{{ cat_value }}'">
          <div class="mb-4">
            <label for="subcategory" class="block text-sm font-medium text-gray-700 mb-1">
              Sous-type
            </label>
            <select id="subcategory" name="subcategory"
                    class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500">
              <option value="">— Choisissez un sous-type —</option>
              {% for opt in options %}
                <option value="{{ opt }}"
                        {% if form.subcategory.data == opt %}selected{% endif %}>
                  {{ opt }}
                </option>
              {% endfor %}
            </select>
          </div>
        </template>
      {% endfor %}

      {# Bug #0187 — Journalism-only extension block : taxonomies +
         work-mode flags. Rendered only when the chosen category is
         « journalisme ». Each multi-select is backed by the KYC
         ontology of the same name ; users hold Cmd/Ctrl to pick
         several entries. #}
      {% macro render_multi(field) %}
        <div class="mb-4">
          {{ field.label(class="block text-sm font-medium text-gray-700 mb-1") }}
          {{ field(class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500",
                   size=4) }}
          <p class="mt-1 text-xs text-gray-500">
            Maintenez Cmd (macOS) ou Ctrl (Windows) pour sélectionner
            plusieurs entrées.
          </p>
          {% if field.errors %}
            <div class="mt-1 text-sm text-red-600">
              {% for error in field.errors %}<span>{{ error }}</span>{% endfor %}
            </div>
          {% endif %}
        </div>
      {% endmacro %}

      <div x-show="category === 'journalisme'" x-cloak class="border-t border-gray-200 pt-4 mt-2">
        <p class="text-sm font-medium text-gray-700 mb-3">
          Fiche descriptive (réservée aux missions Journalisme)
        </p>
        {{ render_multi(form.metiers_journalisme) }}
        {{ render_multi(form.types_entreprises_presse_medias) }}
        {{ render_multi(form.types_presse_medias) }}
        {{ render_multi(form.competences_journalisme) }}
        {{ render_multi(form.langues) }}
        {{ render_multi(form.types_contenus_editoriaux) }}
        {{ render_multi(form.taille_contenus_editoriaux) }}
        {{ render_multi(form.modes_remuneration) }}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-2">
          <label class="flex items-center gap-2 text-sm text-gray-700">
            {{ form.physical_required(class="rounded border-gray-300") }}
            <span>{{ form.physical_required.label.text }}</span>
          </label>
          <label class="flex items-center gap-2 text-sm text-gray-700">
            {{ form.remote_required(class="rounded border-gray-300") }}
            <span>{{ form.remote_required.label.text }}</span>
          </label>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {{ render_field(form.sector) }}
        {{ render_field(form.budget_min, extra_class="no-spinner") }}
        {{ render_field(form.budget_max, extra_class="no-spinner") }}
        {{ render_field(form.deadline) }}
      </div>
      <div class="mb-4">
        {{ form.pays_zip_ville.label(class="block text-sm font-medium text-gray-700 mb-1") }}
        {{ form.pays_zip_ville() }}
      </div>
      <div class="mt-6">
        {{ poster_card(
            g.user,
            title="Information de contact",
            footer="Les candidatures vous parviendront par notification et par e-mail. Votre profil s'affichera sur l'annonce."
        ) }}
      </div>
      <div class="flex space-x-3 mt-6">
        <button type="submit"
                class="bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-md">
          Publier
        </button>
        <a href="{{ url_for('biz.biz', current_tab='missions') }}"
           class="bg-gray-200 hover:bg-gray-300 text-gray-800 font-medium py-2 px-4 rounded-md">
          Annuler
        </a>
      </div>
    </form>
  </div>
</div>
{% endblock %}
