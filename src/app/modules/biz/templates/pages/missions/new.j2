{% extends "layout/private.j2" %}

{% macro render_field(field, extra_class="") %}
  <div class="mb-4">
    {{ field.label(class="block text-sm font-medium text-gray-700 mb-1") }}
    {{ field(class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 " + extra_class + (" border-red-500" if field.errors else "")) }}
    {% if field.errors %}
      <div class="mt-1 text-sm text-red-600">
        {% for error in field.errors %}<span>{{ error }}</span>{% endfor %}
      </div>
    {% endif %}
  </div>
{% endmacro %}

{% block content %}
<div class="py-10">
  <div class="mx-auto max-w-3xl px-6">
    <h1 class="text-2xl font-semibold text-gray-800 mb-6">
      Publier une mission
    </h1>
    <form method="post" class="bg-white p-6 rounded-lg shadow">
      {{ render_field(form.title) }}
      {{ render_field(form.description, extra_class="min-h-[160px]") }}
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {{ render_field(form.sector) }}
        {{ render_field(form.location) }}
        {{ render_field(form.budget_min) }}
        {{ render_field(form.budget_max) }}
        {{ render_field(form.deadline) }}
        {{ render_field(form.contact_email) }}
      </div>
      <div class="flex space-x-3 mt-6">
        <button type="submit"
                class="bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-md">
          Publier
        </button>
        <a href="{{ url_for('biz.biz', current_tab='missions') }}"
           class="bg-gray-200 hover:bg-gray-300 text-gray-800 font-medium py-2 px-4 rounded-md">
          Annuler
        </a>
      </div>
    </form>
  </div>
</div>
{% endblock %}
