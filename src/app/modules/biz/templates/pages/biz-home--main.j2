{% from "macros/selector.j2" import selector %}

<div x-data="{ showFilters: false, showSorter: false }">
  {{ component("biz-tabs", tabs) }}

  <div
      x-cloak
      x-show="showFilters"
      x-transition.opacity
      class="flex items-center flex-wrap mb-4 gap-2 text-gray-700">
    <div>Filtrer par:</div>
    {% for filter in filters %}
      {{ selector(filter.label, filter.options) }}
    {% endfor %}
  </div>
</div>

{% if request.args.get("current_tab", "stories") == "missions" %}
  <div class="mb-4">
    <a href="{{ url_for('biz.missions_new') }}"
       class="inline-flex items-center bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium py-2 px-4 rounded-md">
      + Publier une mission
    </a>
  </div>
{% endif %}

<ul role="list" class="grid gap-6 grid-cols-1 lg:grid-cols-2">
  {% for obj in objs %}
    <li class="bg-white rounded-lg shadow">
      {% if obj.type == "mission_offer" %}
        {% include "pages/missions/_card.j2" %}
      {% else %}
        {{ biz_card(obj) }}
      {% endif %}
    </li>
  {% endfor %}
</ul>
