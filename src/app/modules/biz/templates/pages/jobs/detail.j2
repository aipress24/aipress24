{% extends "layout/private.j2" %}

{% block content %}
<div class="py-10">
  <div class="mx-auto max-w-4xl px-6">
    <div class="bg-white p-6 rounded-lg shadow">
      <div class="flex items-center justify-between mb-4">
        <h1 class="text-2xl font-semibold text-gray-900">{{ job.title }}</h1>
        {% if job.mission_status.value == "FILLED" %}
          <span class="bg-gray-200 text-gray-700 text-xs px-2 py-1 rounded">Pourvu</span>
        {% elif job.mission_status.value == "CLOSED" %}
          <span class="bg-red-100 text-red-700 text-xs px-2 py-1 rounded">Fermé</span>
        {% else %}
          <span class="bg-green-100 text-green-700 text-xs px-2 py-1 rounded">Ouvert</span>
        {% endif %}
      </div>

      <dl class="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm text-gray-600 mb-6">
        <div><dt class="text-gray-500">Contrat</dt><dd>{{ job.contract_type.value }}{% if not job.full_time %} — temps partiel{% endif %}</dd></div>
        {% if job.sector %}<div><dt class="text-gray-500">Secteur</dt><dd>{{ job.sector }}</dd></div>{% endif %}
        {% set _geo = job|offer_geoloc %}
        {% if _geo %}<div><dt class="text-gray-500">Lieu</dt><dd>{{ _geo }}{% if job.remote_ok %} (télétravail OK){% endif %}</dd></div>{% endif %}
        {% if job.salary_min or job.salary_max %}
          <div>
            <dt class="text-gray-500">Salaire</dt>
            <dd>
              {% if job.salary_min and job.salary_max %}
                {{ (job.salary_min / 100)|int }}&nbsp;€ — {{ (job.salary_max / 100)|int }}&nbsp;€
              {% elif job.salary_min %}
                à partir de {{ (job.salary_min / 100)|int }}&nbsp;€
              {% elif job.salary_max %}
                jusqu'à {{ (job.salary_max / 100)|int }}&nbsp;€
              {% endif %}
              brut/an
            </dd>
          </div>
        {% endif %}
        {% if job.starting_date %}
          <div><dt class="text-gray-500">Prise de poste</dt><dd>{{ job.starting_date.strftime("%d/%m/%Y") }}</dd></div>
        {% endif %}
      </dl>

      <div class="prose max-w-none text-gray-800 mb-8">{{ job.description|safe }}</div>

      {% if is_owner %}
        <div class="border-t pt-6 flex flex-wrap gap-2">
          <a href="{{ url_for('.jobs_applications', id=job.id) }}"
             class="bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-md">
            Voir les candidatures reçues
          </a>
          {% if job.mission_status.value == "OPEN" %}
            <form method="post" action="{{ url_for('.jobs_fill', id=job.id) }}" class="inline">
              <button type="submit"
                      class="bg-gray-200 hover:bg-gray-300 text-gray-800 font-medium py-2 px-4 rounded-md">
                Marquer comme pourvu
              </button>
            </form>
          {% endif %}
        </div>
      {% elif user_application %}
        <div class="border-t pt-6 text-sm text-gray-700">
          Vous avez déjà candidaté le {{ user_application.created_at.format("DD/MM/YYYY") if user_application.created_at else "" }}.
          Statut : <strong>{{ user_application.status.value }}</strong>.
        </div>
      {% elif job.mission_status.value == "OPEN" %}
        <form method="post" action="{{ url_for('.jobs_apply', id=job.id) }}" class="border-t pt-6">
          <label class="block text-sm font-medium text-gray-700 mb-1">
            Votre message
          </label>
          <textarea name="message" rows="4" required
                    class="w-full px-3 py-2 border border-gray-300 rounded-md mb-4"
                    placeholder="Votre motivation, votre parcours, ce que vous pouvez apporter."></textarea>
          <label class="block text-sm font-medium text-gray-700 mb-1">
            Lien vers votre CV (optionnel)
          </label>
          <input type="url" name="cv_url"
                 class="w-full px-3 py-2 border border-gray-300 rounded-md mb-4"
                 placeholder="https://...">
          <button type="submit"
                  class="bg-green-600 hover:bg-green-700 text-white font-medium py-2 px-4 rounded-md">
            Candidater
          </button>
        </form>
      {% else %}
        <div class="border-t pt-6 text-sm text-gray-500 italic">
          Cette offre n'accepte plus de candidatures.
        </div>
      {% endif %}
    </div>

    <div class="mt-6">
      <a href="{{ url_for('biz.biz', current_tab='jobs') }}"
         class="text-blue-600 hover:underline text-sm">
        ← Retour aux offres d'emploi
      </a>
    </div>
  </div>
</div>
{% endblock %}
