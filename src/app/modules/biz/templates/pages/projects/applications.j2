{% extends "layout/private.j2" %}
{% from "macros/_poster_card.j2" import poster_card %}

{% block content %}
<div class="py-10">
  <div class="mx-auto max-w-4xl px-6">
    <h1 class="text-2xl font-semibold text-gray-900 mb-2">
      Candidatures : {{ project.title }}
    </h1>
    <a href="{{ url_for('.projects_detail', id=project.id) }}"
       class="text-blue-600 hover:underline text-sm">
      ← Retour au projet
    </a>

    {% if not applications %}
      <p class="mt-6 text-gray-600">Aucune candidature pour le moment.</p>
    {% else %}
      <ul class="mt-6 space-y-4">
        {% for app in applications %}
          <li class="bg-white p-4 rounded-lg shadow border border-gray-100">
            <div class="flex items-start justify-between mb-3">
              <div class="text-xs text-gray-500">
                {{ app.created_at.format("DD/MM/YYYY HH:mm", locale="fr") if app.created_at else "" }}
              </div>
              <div>
                {% if app.status.value == "SELECTED" %}
                  <span class="bg-green-100 text-green-700 text-xs px-2 py-1 rounded">Sélectionné</span>
                {% elif app.status.value == "REJECTED" %}
                  <span class="bg-red-100 text-red-700 text-xs px-2 py-1 rounded">Refusé</span>
                {% else %}
                  <span class="bg-yellow-100 text-yellow-700 text-xs px-2 py-1 rounded">En attente</span>
                {% endif %}
              </div>
            </div>

            {# Bug #0184 — mini-card du répondant. #}
            {% if app.owner %}
              {{ poster_card(app.owner, show_bw_link=True) }}
            {% else %}
              <div class="font-medium text-gray-900">Candidat inconnu</div>
            {% endif %}

            {% if app.message %}
              <div class="mt-3 text-sm text-gray-700 whitespace-pre-line">{{ app.message }}</div>
            {% endif %}

            {% if app.status.value == "PENDING" %}
              {# Tickets #0199 + #0200 — emitter writes a free-text
                 decision message, e-mailed + in-app posted to the
                 candidate. Same form, two submit buttons. #}
              <form method="post" class="mt-4" x-data="{ open: false }">
                <textarea name="decision_message"
                          rows="2"
                          maxlength="2000"
                          x-show="open"
                          x-cloak
                          placeholder="Message destiné au candidat (optionnel)…"
                          class="w-full mb-2 px-3 py-2 border border-gray-300 rounded-md text-sm shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500"></textarea>
                <div class="flex flex-wrap gap-2 items-center">
                  <button type="button"
                          x-show="!open"
                          x-on:click="open = true"
                          class="text-xs text-blue-600 hover:underline">
                    + Ajouter un message
                  </button>
                  <button type="submit"
                          formaction="{{ url_for('.projects_application_select', id=project.id, app_id=app.id) }}"
                          class="bg-green-600 hover:bg-green-700 text-white text-sm py-1 px-3 rounded">
                    Sélectionner
                  </button>
                  <button type="submit"
                          formaction="{{ url_for('.projects_application_reject', id=project.id, app_id=app.id) }}"
                          class="bg-gray-200 hover:bg-gray-300 text-gray-800 text-sm py-1 px-3 rounded">
                    Refuser
                  </button>
                </div>
              </form>
            {% endif %}

            {% if app.decision_message and app.status.value in ("SELECTED", "REJECTED") %}
              <div class="mt-3 text-xs text-gray-500">Message envoyé :</div>
              <div class="text-sm text-gray-700 whitespace-pre-line italic">{{ app.decision_message }}</div>
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    {% endif %}
  </div>
</div>
{% endblock %}
