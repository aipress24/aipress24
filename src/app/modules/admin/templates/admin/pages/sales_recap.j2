{% extends "admin/layout/_base.j2" %}

{% block main %}
  <h1 class="text-2xl font-semibold text-gray-900 mb-6">{{ header }}</h1>

  <div class="mb-6 bg-gray-50 border border-gray-200 rounded p-4">
    <div class="text-xs uppercase text-gray-500">Total</div>
    <div class="text-2xl font-semibold text-gray-900">{{ "%.2f"|format(total_eur) }} € HT</div>
  </div>

  {% if rows %}
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">{{ column_label }}</th>
          <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 uppercase">Total (HT)</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        {% for r in rows %}
          <tr>
            <td class="px-4 py-2 text-sm text-gray-900">{{ r.org_name }}</td>
            <td class="px-4 py-2 text-right text-sm text-gray-900">{{ "%.2f"|format(r.total_eur) }} €</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  {% else %}
    <p class="text-sm text-gray-600">{{ empty_message }}</p>
  {% endif %}
{% endblock %}
