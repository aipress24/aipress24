{% extends "admin/layout/_base.j2" %}

{% block main %}
    <div class="bg-white shadow overflow-hidden sm:rounded-lg border border-gray-200">
        <div class="px-4 py-5 sm:p-6 text-center">
            <h3 class="text-lg leading-6 font-medium text-gray-900">{{ title }}</h3>
            <div class="mt-2 max-w-xl text-sm text-gray-500 mx-auto">
                <p>
                    {{ message }}
                </p>
            </div>
            <div class="mt-5">
                <a href="{{ back_url }}" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
                    Retour à la page de test
                </a>
            </div>
        </div>
    </div>
{% endblock %}
